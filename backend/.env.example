# Database
DATABASE_URL="postgresql://user:password@localhost:5432/driver_recruitment_hub?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"

# AWS S3
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="xpress-driver-recruitment-docs"

# OpsTower V3 Integration
OPSTOWER_API_URL="https://api.opstower.xpress.ph"
OPSTOWER_API_KEY=""

# Marketing Hub Integration
MARKETING_HUB_API_URL="https://api.marketing.xpress.ph"
MARKETING_HUB_API_KEY=""

# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Resend (Email)
RESEND_API_KEY=""
FROM_EMAIL="recruitment@xpress.ph"

# Application
CANDIDATE_PORTAL_URL="https://apply.xpress.ph"
